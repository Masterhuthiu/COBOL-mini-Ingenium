IDENTIFICATION DIVISION.
PROGRAM-ID. TESTCOBOL.

ENVIRONMENT DIVISION.

DATA DIVISION.
WORKING-STORAGE SECTION.
EXEC SQL BEGIN DECLARE SECTION END-EXEC.
01 DB-NAME          PIC X(20).
01 DB-VERSION       PIC X(50).
EXEC SQL END DECLARE SECTION END-EXEC.
01 SQLCODE          PIC S9(9) COMP VALUE 0.

PROCEDURE DIVISION.
    DISPLAY "=== COBOL + SQLite TEST START ===".

    EXEC SQL CONNECT TO 'test.db' END-EXEC.
    IF SQLCODE NOT = 0
        DISPLAY "ERROR: Cannot connect to DB, SQLCODE=" SQLCODE
        STOP RUN
    END-IF.
    DISPLAY "DB CONNECTED OK".

    EXEC SQL
        CREATE TABLE IF NOT EXISTS test_table (
            id   INTEGER PRIMARY KEY,
            name TEXT
        )
    END-EXEC.

    EXEC SQL
        INSERT INTO test_table (id, name) VALUES (1, 'HELLO FROM COBOL')
    END-EXEC.

    EXEC SQL
        SELECT name INTO :DB-VERSION
        FROM test_table WHERE id = 1
    END-EXEC.

    DISPLAY "DATA READ: " DB-VERSION.

    EXEC SQL DROP TABLE test_table END-EXEC.
    EXEC SQL COMMIT END-EXEC.
    EXEC SQL DISCONNECT CURRENT END-EXEC.

    DISPLAY "=== TEST PASSED ===".
    STOP RUN.